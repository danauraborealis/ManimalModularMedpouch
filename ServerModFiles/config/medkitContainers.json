{
  // set uninstall to true and relaunch to drop the medkit conversion.
  "uninstall": false,

  // bots get live med clones so they can heal. on death those clones swap back to filled containers.
  "convertBotMedsOnDeath": true,

  // meds allowed inside any converted medkit. add/remove to taste.
  "filter": [
    "544fb25a4bdc2dfb738b4567", // bandage
    "5751a25924597722c463c472", // army bandage
    "5755356824597772cb798962", // ai-2 kit
    "7d1a9c5e8f2b4d3a7c0e1fa2", // super ai-2 kit
    "69eff94e0842b5b5bbd1fd4d", // MEGA ai-2 kit
    "544fb3364bdc2d34748b456a", // splint
    "5af0454c86f7746bf20992e8", // alu splint
    "6937ecf8628ee476240c07cb", // tigz splint
    "5e831507ea0a7c419c2f9bd9", // esmarch
    "60098af40accd37ef2175f27", // CAT
    "5e8488fa988a8701445df1e4"  // calok-b
  ],

  // seconds to play the vanilla unzip animation before cancelling and starting the heal chain.
  // top-level value is the default; per medkit override goes inside the medkits block.
  // zero or negative disables the flourish.
  "animationDelaySeconds": 1,

  // medkit id -> internal grid size. cellsH x cellsV. omit an id to leave it as a vanilla medkit.
  // per medkit filter override is optional. per medkit animationDelaySeconds is optional and
  // overrides the top-level default.
  "medkits": {
    "544fb45d4bdc2dee738b4568": { "name": "salewa",  "cellsH": 4, "cellsV": 1, "animationDelaySeconds": 1 },
    "590c657e86f77412b013051d": { "name": "grizzly", "cellsH": 3, "cellsV": 3, "animationDelaySeconds": 1 },
    "590c661e86f7741e566b646a": { "name": "car",     "cellsH": 3, "cellsV": 1, "animationDelaySeconds": 1 },
    "590c678286f77426c9660122": { "name": "ifak",    "cellsH": 2, "cellsV": 2, "animationDelaySeconds": 1 },
    "60098ad7c2240c0fe85c570a": { "name": "afak",    "cellsH": 2, "cellsV": 2, "animationDelaySeconds": 1 }
  },

  // controls the loot fill that runs when SPT spawns one of our converted medkits. each category
  // has a chance and an optional override; categories without an override fall back to
  // substitutions. bosses upgrade AI-2 -> MEGA AI-2 (100%); their followers upgrade to Super AI-2
  // (100%); cultists Super AI-2 (60%); PMCs/raiders/rogues Super AI-2 (50%);
  // static + loose loot Super AI-2 (30%); regular scavs never substitute.
  "loot": {
    "fill": true,
    "guaranteedTpl": "5755356824597772cb798962", //ai2
    "substitutions": {
      "5755356824597772cb798962": "7d1a9c5e8f2b4d3a7c0e1fa2" //super ai2
    },
    "bossSubstitutions": {
      "5755356824597772cb798962": "69eff94e0842b5b5bbd1fd4d" //mega ai2
    },
    "bossSubstitutionChance": 1.0,
    "followerSubstitutionChance": 1.0,
    "pmcSubstitutionChance": 0.5,
    "cultistSubstitutionChance": 0.6,
    "lootSubstitutionChance": 0.3
  },

  // when the hotkey for a converted medkit is pressed the patch walks effectPriority top-down,
  // finds the first bucket the player has an active need for, then picks an item in the pouch.
  "effectPriority": ["heavyBleed", "lightBleed", "fracture", "hpHeal"],
  "effectItems": {
    "heavyBleed": [
      "5e831507ea0a7c419c2f9bd9", // esmarch
      "60098af40accd37ef2175f27", // CAT
      "5e8488fa988a8701445df1e4"  // calok-b
    ],
    "lightBleed": [
      "544fb25a4bdc2dfb738b4567", // bandage
      "5751a25924597722c463c472"  // army bandage
    ],
    "fracture": [
      "544fb3364bdc2d34748b456a", // splint
      "5af0454c86f7746bf20992e8", // alu splint
      "6937ecf8628ee476240c07cb"  // tigz splint
    ],
    "hpHeal": [
      "5755356824597772cb798962", //ai2
      "7d1a9c5e8f2b4d3a7c0e1fa2", //super ai2
      "69eff94e0842b5b5bbd1fd4d"  //mega ai2
    ]
  }
}
